---
interface Props {
  variant?: 'mid' | 'end';
}
const { variant = 'end' } = Astro.props;
---

<div class:list={['cal-ad', `cal-ad--${variant}`]}>
  <div class="cal-ad-inner">
    <div class="cal-ad-left">
      <div class="cal-ad-tag">◆ Sistema · Fluxy</div>
      <div class="cal-ad-title">
        {variant === 'end'
          ? 'Quer ver o sistema funcionando na prática?'
          : 'Agende uma apresentação do sistema'}
      </div>
      <p class="cal-ad-desc">
        {variant === 'end'
          ? 'O Fluxy foi construído dentro de uma construtora real e pode ser implementado na sua operação. Agende uma conversa de 30 minutos — sem compromisso.'
          : 'Veja como o fluxo centralizado funciona aplicado à sua operação. Conversa de 30 min, sem compromisso.'}
      </p>
    </div>
    <div class="cal-ad-right">
      <div class="cal-ad-label">Demonstração gratuita</div>
      <a
        href="https://calendly.com/josericardovj/demonstracao-fluxy"
        class="cal-ad-btn"
        target="_blank"
        rel="noopener"
      >
        Agendar apresentação →
      </a>
      <div class="cal-ad-note">📅 30 minutos · Online · Sem compromisso</div>
    </div>
  </div>
</div>

<style>
  .cal-ad {
    background: linear-gradient(135deg, #0a0a00 0%, #0f0f0f 100%);
    border: 1px solid rgba(245,168,0,0.25);
    border-left: 4px solid var(--amber);
    border-radius: 4px;
    padding: 28px 28px;
    margin: 40px 0;
  }
  .cal-ad--end {
    background: linear-gradient(135deg, #0c0b00 0%, #0d0d0d 100%);
  }
  .cal-ad-inner {
    display: grid; grid-template-columns: 1fr auto;
    gap: 28px; align-items: center;
  }
  @media (max-width: 600px) {
    .cal-ad-inner { grid-template-columns: 1fr; }
  }
  .cal-ad-tag {
    font-family: var(--font-cond); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--amber); margin-bottom: 8px;
  }
  .cal-ad-title {
    font-family: var(--font-display); font-size: 1.6rem;
    letter-spacing: 0.03em; color: #fff; margin-bottom: 8px; line-height: 1;
  }
  .cal-ad-desc {
    font-size: 0.88rem; color: var(--muted);
    line-height: 1.6; font-family: var(--font-body);
  }
  .cal-ad-right {
    text-align: center; min-width: 200px;
  }
  .cal-ad-label {
    font-family: var(--font-cond); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--amber); margin-bottom: 14px;
  }
  .cal-ad-btn {
    display: block; background: var(--amber); color: #000 !important;
    font-family: var(--font-cond); font-size: 0.88rem;
    font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 12px 20px; border-radius: 3px; text-decoration: none !important;
    text-align: center; transition: opacity 0.15s;
    box-shadow: 0 4px 20px rgba(245,168,0,0.3);
    margin-bottom: 10px;
  }
  .cal-ad-btn:hover { opacity: 0.88; }
  .cal-ad-note {
    font-family: var(--font-cond); font-size: 0.66rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--faint);
  }
</style>
