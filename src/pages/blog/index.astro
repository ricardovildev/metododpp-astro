---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base
  title="Blog — Método DPP · Gestão Operacional e Processos"
  description="Artigos práticos sobre gestão de processos, organização operacional e uso de IA em empresas — especialmente na construção civil."
>
  <Header />

  <div class="blog-hero">
    <div class="blog-hero-inner">
      <div class="blog-hero-tag">◆ Conteúdo gratuito</div>
      <h1 class="blog-hero-title">Blog <span>Método DPP</span></h1>
      <p class="blog-hero-desc">Gestão de processos, organização operacional e IA aplicada — conteúdo prático direto de quem implementou em ambiente real.</p>
    </div>
  </div>

  <div class="blog-body">
    <div class="blog-grid">
      {posts.length === 0 && (
        <div class="blog-empty">
          <p>Primeiros artigos em breve.</p>
        </div>
      )}
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-card-meta">
            <span class="post-card-category">{post.data.category}</span>
            <span class="post-card-date">
              {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
            </span>
          </div>
          <h2 class="post-card-title">{post.data.title}</h2>
          <p class="post-card-desc">{post.data.description}</p>
          <div class="post-card-footer">
            <span class="post-card-read">Ler artigo →</span>
            {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
              <span class="post-card-tag">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <aside class="blog-sidebar">
      <div class="sidebar-block">
        <div class="sidebar-block-title">◆ O Curso</div>
        <div class="sidebar-course">
          <div class="sidebar-course-name">Método DPP</div>
          <p class="sidebar-course-desc">Do diagnóstico ao produto digital. Método validado em operação real na construção civil.</p>
          <div class="sidebar-course-price">R$ 197,00</div>
          <a href="https://pay.hotmart.com/O105466115V" class="sidebar-course-btn" target="_blank" rel="noopener">Garantir acesso →</a>
          <div class="sidebar-course-guarantee">🛡️ 7 dias de garantia</div>
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Base>

<style>
  /* HERO */
  .blog-hero {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 64px 24px 52px;
    position: relative; overflow: hidden;
  }
  .blog-hero::before {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 54px 54px; opacity: 0.12;
  }
  .blog-hero::after {
    content: ''; position: absolute;
    top: -100px; left: -100px; width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(245,108,0,0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .blog-hero-inner {
    position: relative; z-index: 1;
    max-width: 800px; margin: 0 auto;
  }
  .blog-hero-tag {
    font-family: var(--font-cond); font-size: 0.74rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--orange);
    margin-bottom: 14px;
  }
  .blog-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 0.95; letter-spacing: 0.02em;
    color: #fff; margin-bottom: 16px;
  }
  .blog-hero-title span { color: var(--orange); }
  .blog-hero-desc {
    font-size: 1.05rem; color: var(--muted);
    line-height: 1.65; font-weight: 400; max-width: 560px;
  }

  /* BODY */
  .blog-body {
    max-width: 1100px; margin: 0 auto; padding: 52px 24px 80px;
    display: grid; grid-template-columns: 1fr 280px; gap: 48px;
  }
  @media (max-width: 900px) {
    .blog-body { grid-template-columns: 1fr; }
    .blog-sidebar { display: none; }
  }

  /* GRID */
  .blog-grid { display: flex; flex-direction: column; gap: 2px; }
  .blog-empty {
    font-family: var(--font-cond); font-size: 1rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--faint); padding: 40px 0;
  }

  /* POST CARD */
  .post-card {
    background: var(--surface); border: 1px solid var(--border);
    padding: 28px 26px; text-decoration: none; color: var(--text);
    display: block; position: relative; overflow: hidden;
    transition: border-color 0.22s;
  }
  .post-card:hover { border-color: rgba(245,108,0,0.35); }
  .post-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 2px; height: 0; background: var(--orange); transition: height 0.3s;
  }
  .post-card:hover::before { height: 100%; }
  .post-card-meta {
    display: flex; align-items: center; gap: 12px; margin-bottom: 10px;
    font-family: var(--font-cond); font-size: 0.7rem;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .post-card-category { color: var(--orange); font-weight: 700; }
  .post-card-date { color: var(--faint); }
  .post-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1; letter-spacing: 0.02em;
    color: #fff; margin-bottom: 10px;
  }
  .post-card-desc {
    font-size: 0.92rem; color: var(--muted);
    line-height: 1.62; font-weight: 400; margin-bottom: 16px;
  }
  .post-card-footer {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .post-card-read {
    font-family: var(--font-cond); font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--orange);
  }
  .post-card-tag {
    font-family: var(--font-cond); font-size: 0.65rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--faint); background: var(--bg3);
    border: 1px solid var(--border); padding: 3px 8px; border-radius: 2px;
  }

  /* SIDEBAR */
  .blog-sidebar { padding-top: 0; }
  .sidebar-block {
    background: var(--surface); border: 1px solid var(--border);
    border-top: 3px solid var(--orange); border-radius: 3px;
    padding: 22px 18px; position: sticky; top: 76px;
  }
  .sidebar-block-title {
    font-family: var(--font-cond); font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--orange);
    margin-bottom: 14px;
  }
  .sidebar-course-name {
    font-family: var(--font-display); font-size: 1.8rem;
    letter-spacing: 0.04em; color: #fff; margin-bottom: 8px;
  }
  .sidebar-course-desc {
    font-size: 0.82rem; color: var(--muted);
    line-height: 1.6; margin-bottom: 14px;
  }
  .sidebar-course-price {
    font-family: var(--font-display); font-size: 2.2rem;
    color: var(--orange); line-height: 1; margin-bottom: 12px;
  }
  .sidebar-course-btn {
    display: block; background: var(--orange); color: #fff;
    font-family: var(--font-cond); font-size: 0.82rem;
    font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 11px 16px; border-radius: 3px; text-decoration: none;
    text-align: center; margin-bottom: 10px; transition: opacity 0.15s;
  }
  .sidebar-course-btn:hover { opacity: 0.88; }
  .sidebar-course-guarantee {
    font-family: var(--font-cond); font-size: 0.62rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--faint); text-align: center;
  }
</style>
