---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Página não encontrada | Método DPP"
  description="A página que você procura não existe. Volte ao início ou acesse o blog do Método DPP."
  noindex={true}
>
  <Header />

  <main class="err-wrap">
    <div class="err-inner">
      <div class="err-code">404</div>
      <div class="err-tag">Página não encontrada</div>
      <h1 class="err-title">Esse caminho<br><span>não existe</span></h1>
      <p class="err-desc">A página que você procura foi removida, teve o endereço alterado ou nunca existiu.</p>
      <div class="err-actions">
        <a href="/" class="err-btn-primary">Voltar ao início →</a>
        <a href="/blog" class="err-btn-secondary">Ver o blog</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .err-wrap {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 24px;
    position: relative;
    overflow: hidden;
  }
  .err-wrap::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.12;
  }
  .err-inner {
    position: relative; z-index: 1;
    text-align: center;
    max-width: 560px;
  }
  .err-code {
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 14rem);
    line-height: 1;
    color: rgba(245,108,0,0.12);
    letter-spacing: 0.04em;
    margin-bottom: -20px;
  }
  .err-tag {
    font-family: var(--font-cond);
    font-size: 0.76rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--orange); margin-bottom: 16px;
  }
  .err-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1; letter-spacing: 0.02em;
    color: #fff; margin-bottom: 18px;
  }
  .err-title span { color: var(--orange); }
  .err-desc {
    font-size: 1rem; color: var(--muted);
    line-height: 1.7; margin-bottom: 36px;
  }
  .err-actions {
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
  }
  .err-btn-primary {
    display: inline-flex; align-items: center;
    background: var(--orange); color: #fff;
    font-family: var(--font-cond); font-size: 0.95rem;
    font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 14px 28px; border-radius: 3px; text-decoration: none;
    transition: opacity 0.15s;
    box-shadow: 0 4px 20px rgba(245,108,0,0.35);
  }
  .err-btn-primary:hover { opacity: 0.88; }
  .err-btn-secondary {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--muted);
    font-family: var(--font-cond); font-size: 0.95rem;
    font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 14px 28px; border-radius: 3px; text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .err-btn-secondary:hover { border-color: var(--orange); color: var(--orange); }
</style>
