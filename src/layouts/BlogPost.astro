---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CourseAd from '../components/CourseAd.astro';
import CalendlyAd from '../components/CalendlyAd.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  image?: string;
  cta?: 'course' | 'calendly' | 'both';
}

const { title, description, pubDate, category, tags = [], image, cta = 'course' } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const readingTimeWords = 200; // estimativa, pode ser calculada dinamicamente
---

<Base title={`${title.length > 60 ? title.slice(0, 57) + '...' : title} | Método DPP`} description={description} ogImage={image}>
  <Header />

  <div class="article-hero">
    <div class="article-hero-inner">
      <div class="article-meta-top">
        <span class="article-category">{category}</span>
        <span class="article-sep">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span class="article-sep">·</span>
        <span>~{readingTimeWords} palavras</span>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-description">{description}</p>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
      )}
    </div>
  </div>

  <div class="article-body-wrap">
    <main class="article-content">

      <!-- AdSense slot — topo do artigo -->
      <!--
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-XXXXXXX"
        data-ad-slot="XXXXXXXXXX"
        data-ad-format="auto"
        data-full-width-responsive="true">
      </ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      -->

      <slot />

      {(cta === 'course' || cta === 'both') && <CourseAd variant="end" />}
      {(cta === 'calendly' || cta === 'both') && <CalendlyAd variant="end" />}

      <!-- AdSense slot — final do artigo -->
      <!--
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-XXXXXXX"
        data-ad-slot="XXXXXXXXXX"
        data-ad-format="auto"
        data-full-width-responsive="true">
      </ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      -->
    </main>

    <aside class="article-sidebar">
      <div class="sidebar-sticky">
        <div class="sidebar-cta">
          <div class="sidebar-cta-tag">◆ Curso</div>
          <div class="sidebar-cta-title">Método DPP</div>
          <p class="sidebar-cta-desc">Do diagnóstico ao produto digital. Validado em operação real.</p>
          <div class="sidebar-cta-price">R$ 197,00</div>
          <a href="https://pay.hotmart.com/O105466115V" class="sidebar-cta-btn" target="_blank" rel="noopener">
            Garantir acesso →
          </a>
          <div class="sidebar-cta-guarantee">🛡️ 7 dias de garantia</div>
        </div>

        <div class="sidebar-calendly">
          <div class="sidebar-calendly-tag">◆ Sistema · Fluxy</div>
          <div class="sidebar-calendly-title">Ver o sistema</div>
          <p class="sidebar-calendly-desc">Apresentação gratuita de 30 min para donos e gestores de construtoras.</p>
          <a href="https://calendly.com/josericardovj/demonstracao-fluxy" class="sidebar-calendly-btn" target="_blank" rel="noopener">
            Agendar demonstração →
          </a>
          <div class="sidebar-calendly-note">📅 Online · Sem compromisso</div>
        </div>

        <!-- AdSense slot — sidebar -->
        <!--
        <ins class="adsbygoogle"
          style="display:block;margin-top:24px"
          data-ad-client="ca-pub-XXXXXXX"
          data-ad-slot="XXXXXXXXXX"
          data-ad-format="auto">
        </ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        -->
      </div>
    </aside>
  </div>

  <Footer />
</Base>

<style>
  /* ARTICLE HERO — dark */
  .article-hero {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 56px 24px 48px;
    position: relative; overflow: hidden;
  }
  .article-hero::before {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 54px 54px; opacity: 0.12;
  }
  .article-hero-inner {
    position: relative; z-index: 1;
    max-width: 800px; margin: 0 auto;
  }
  .article-meta-top {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    font-family: var(--font-cond); font-size: 0.76rem;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--faint); margin-bottom: 18px;
  }
  .article-category {
    color: var(--orange); font-weight: 700;
  }
  .article-sep { color: var(--border); }
  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 0.97; letter-spacing: 0.02em;
    color: #fff; margin-bottom: 16px;
  }
  .article-description {
    font-size: 1.05rem; color: var(--muted);
    line-height: 1.65; font-weight: 400; max-width: 640px;
    margin-bottom: 18px;
  }
  .article-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    font-family: var(--font-cond); font-size: 0.68rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--faint); background: var(--surface);
    border: 1px solid var(--border); padding: 4px 10px; border-radius: 2px;
  }

  /* ARTICLE BODY WRAP — white */
  .article-body-wrap {
    background: #fff;
    display: grid; grid-template-columns: 1fr 280px;
    gap: 0; max-width: 1100px; margin: 0 auto;
  }
  @media (max-width: 900px) {
    .article-body-wrap { grid-template-columns: 1fr; }
    .article-sidebar { display: none; }
  }

  /* ARTICLE CONTENT */
  .article-content {
    padding: 52px 48px 64px;
    max-width: 720px;
    color: #1a1a1a;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.82;
  }
  @media (max-width: 600px) {
    .article-content { padding: 36px 22px 48px; }
  }

  /* Markdown typography */
  .article-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1; letter-spacing: 0.03em;
    color: #111; margin: 48px 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f0f0f0;
  }
  .article-content :global(h3) {
    font-family: var(--font-cond);
    font-size: 1.2rem; font-weight: 800;
    letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--orange); margin: 32px 0 12px;
  }
  .article-content :global(p) {
    margin-bottom: 20px; color: #2a2a2a;
  }
  .article-content :global(strong) { color: #111; font-weight: 700; }
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 22px; margin-bottom: 22px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .article-content :global(li) { color: #2a2a2a; }
  .article-content :global(blockquote) {
    border-left: 3px solid var(--orange);
    background: #fff8f4; padding: 16px 20px;
    margin: 28px 0; border-radius: 2px;
  }
  .article-content :global(blockquote p) { color: #333; font-style: italic; margin: 0; }
  .article-content :global(code) {
    background: #f4f4f4; padding: 2px 6px;
    border-radius: 3px; font-size: 0.88em; color: #c00;
  }
  .article-content :global(hr) {
    border: none; border-top: 1px solid #eee; margin: 36px 0;
  }
  .article-content :global(a) {
    color: var(--orange); text-decoration: underline; text-underline-offset: 3px;
  }

  /* SIDEBAR */
  .article-sidebar {
    border-left: 1px solid #e8e8e8;
    padding: 52px 24px;
    background: #fafafa;
  }
  .sidebar-sticky {
    position: sticky; top: 80px;
    display: flex; flex-direction: column; gap: 24px;
  }
  .sidebar-cta {
    background: #0d0d0d; border: 1px solid #272727;
    border-top: 3px solid var(--orange);
    border-radius: 4px; padding: 22px 18px;
    text-align: center;
  }
  .sidebar-cta-tag {
    font-family: var(--font-cond); font-size: 0.65rem;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--orange); margin-bottom: 6px;
  }
  .sidebar-cta-title {
    font-family: var(--font-display); font-size: 1.6rem;
    letter-spacing: 0.04em; color: #fff; margin-bottom: 8px;
  }
  .sidebar-cta-desc {
    font-size: 0.78rem; color: var(--muted);
    line-height: 1.55; margin-bottom: 14px;
  }
  .sidebar-cta-price {
    font-family: var(--font-display); font-size: 2rem;
    color: var(--orange); line-height: 1; margin-bottom: 2px;
  }
  .sidebar-cta-btn {
    display: block; background: var(--orange); color: #fff;
    font-family: var(--font-cond); font-size: 0.82rem;
    font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 11px 16px; border-radius: 3px;
    text-decoration: none; margin: 12px 0 8px;
    transition: opacity 0.15s;
  }
  .sidebar-cta-btn:hover { opacity: 0.88; }
  .sidebar-cta-guarantee {
    font-family: var(--font-cond); font-size: 0.62rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint);
  }
  .sidebar-calendly {
    background: #0d0d0d; border: 1px solid #272727;
    border-top: 3px solid var(--amber);
    border-radius: 4px; padding: 22px 18px;
    text-align: center;
  }
  .sidebar-calendly-tag {
    font-family: var(--font-cond); font-size: 0.65rem;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--amber); margin-bottom: 6px;
  }
  .sidebar-calendly-title {
    font-family: var(--font-display); font-size: 1.6rem;
    letter-spacing: 0.04em; color: #fff; margin-bottom: 8px;
  }
  .sidebar-calendly-desc {
    font-size: 0.78rem; color: var(--muted);
    line-height: 1.55; margin-bottom: 14px;
  }
  .sidebar-calendly-btn {
    display: block; background: var(--amber); color: #000;
    font-family: var(--font-cond); font-size: 0.82rem;
    font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 11px 16px; border-radius: 3px;
    text-decoration: none; margin: 0 0 8px;
    transition: opacity 0.15s;
  }
  .sidebar-calendly-btn:hover { opacity: 0.88; }
  .sidebar-calendly-note {
    font-family: var(--font-cond); font-size: 0.62rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint);
  }
</style>
